Package: rbfmvar
Type: Package
Title: Residual-Based Fully Modified Vector Autoregression
Version: 2.0.0
Authors@R: c(
    person("Muhammad", "Alkhalaf", 
           email = "muhammedalkhalaf@gmail.com",
           role = c("aut", "cre", "cph"),
           comment = c(ORCID = "0009-0002-2677-9246")),
